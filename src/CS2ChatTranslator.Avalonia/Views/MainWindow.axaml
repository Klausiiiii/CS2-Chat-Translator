<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CS2ChatTranslator.Views.MainWindow"
        Title="CS2 Chat Translator"
        Width="900" Height="560"
        MinWidth="500" MinHeight="300"
        Background="#181A1E">
  <DockPanel LastChildFill="True">
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_Datei">
        <MenuItem Name="SettingsItem" Header="_Einstellungen…" />
        <Separator />
        <MenuItem Name="ExitItem" Header="_Beenden" />
      </MenuItem>
    </Menu>
    <Border DockPanel.Dock="Bottom"
            BorderBrush="#2A2D33" BorderThickness="0,1,0,0"
            Padding="8,4">
      <TextBlock Name="StatusLabel"
                 Foreground="#C8C8C8"
                 Text="Nicht gestartet — bitte Einstellungen öffnen." />
    </Border>
    <ScrollViewer Name="ChatScroller"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="10,8">
      <SelectableTextBlock Name="ChatBox"
                           FontFamily="Cascadia Mono,Consolas,Menlo,Liberation Mono,monospace"
                           FontSize="13"
                           Foreground="#DCDCDC"
                           TextWrapping="Wrap" />
    </ScrollViewer>
  </DockPanel>
</Window>
